# Copy this file to .env and fill in your key:
#   cp server/.env.example server/.env

# Required: your fal.ai API key (https://fal.ai/dashboard/keys)
FAL_KEY=

# Optional: change the backend port (default 3001)
PORT=3001

# --- User access (Clerk) ---
# Enables sign-in + per-page access control. Without these the app runs open
# (no login, everyone is treated as an admin). Get keys at https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Comma-separated emails that are always admins (full access + can manage people).
# The very first person to sign in is also bootstrapped as an admin automatically.
ADMIN_EMAILS=

# --- Identity anchor provider ---
# Which provider generates the IDENTITY ANCHOR portrait (story page generation,
# photo validation, restore and the checker are unaffected). Both options run
# through fal with the same FAL_KEY above.
#   nano_banana (default) — fal.ai Nano Banana / Gemini image
#   gpt_image_2           — fal.ai "openai/gpt-image-2/edit" endpoint
ANCHOR_PROVIDER=nano_banana

# Alternative to ANCHOR_PROVIDER: point directly at the fal model id.
# ANCHOR_MODEL=openai/gpt-image-2/edit

# --- Stubbed for now (fal-only build) ---
# When you're ready to enable the AI consistency checker, grab a FREE key
# from Google AI Studio (https://aistudio.google.com/apikey) and paste it here.
GEMINI_API_KEY=
